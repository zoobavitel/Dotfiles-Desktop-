{
    "layer": "top",
    "position": "bottom",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 36,
    "modules-left": [
        "custom/powermenu",
        "custom/separator",
        "custom/terminal",
        "custom/filemanager",
        "custom/browser",
        "custom/separator",
        "hyprland/workspaces"
    ],
    "modules-center": ["mpris"],
    "modules-right": [
        "tray",
        "custom/separator-right",
        "custom/pacman",
	"pulseaudio",
        "network",
        "bluetooth",
        "custom/separator-right",
        "clock"
    ],

    "custom/powermenu": {
        "format": "  Start",
        "tooltip": false,
        "on-click": "exec ~/.local/scripts/win95-start.sh"
    },

    "custom/separator": {
        "format": "|",
        "tooltip": false
    },

    "custom/separator-right": {
        "format": "",
        "tooltip": false
    },

    "custom/terminal": {
        "format": "",
        "tooltip-format": "Terminal",
        "on-click": "kitty"
    },

    "custom/filemanager": {
        "format": "",
        "tooltip-format": "Files",
        "on-click": "thunar"
    },

    "custom/browser": {
        "format": "",
        "tooltip-format": "Browser",
        "on-click": "firefox"
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 50,
        "rewrite": {
            "": ""
        }
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "format": "{name}",
        "all-outputs": true,
        "on-click": "activate"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 6
    },

    "clock": {
        "format": " {:%I:%M %p}",
        "format-alt": "  {:%a, %b %e, %Y}",
        "tooltip-format": "<tt><big>{calendar}</big></tt>"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "tooltip": true,
        "tooltip-format": "{volume}%",
        "format-muted": "🔇 Muted",
        "on-click": "pamixer -t",
        "on-click-right": "exec pavucontrol",
        "on-scroll-up": "pamixer -i 5 --allow-boost=true --set-limit=130",
        "on-scroll-down": "pamixer -d 5 --allow-boost=true --set-limit=130",
        "scroll-step": 5,
        "format-icons": {
	    "headphone": " ",
	    "hands-free": " ",
	    "headset": " ",
            "default": ["🔈", "🔉", "🔊"]
        }
    },

    "network": {
        "interface": "enp191s0",
        "tooltip": true,
        "tooltip-format-ethernet": "{ifname} - {bandwidthDownBits}",
        "interval": 2,
        "format": "",
        "format-disconnected": "",
        "on-click-right": "nm-connection-editor"
    },

    "bluetooth": {
        "format": "",
        "format-disabled": "",
        "format-connected": " {num_connections}",
        "tooltip-format": "{device_alias}",
        "tooltip-format-connected": " {device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click-right": "blueman-manager"
    },

    "mpris": {
        "title-len": 40,
        "interval": 1,
        "album-len": 0,
        "max-len": 60,
        "format": "{player_icon} {artist} - {title}",
        "format-paused": "{player_icon} {artist} - {title}",
        "player-icons": {
            "default": "▶",
            "mpv": "🎵",
            "spotify": " ",
            "firefox": ""
        },
        "status-icons": {
            "paused": ""
        },
        "ignored-players": ["vlc", "brave", "chromium"]
    },

    "custom/pacman": {
        "format": "📦 {}",
        "interval": 100,
        "exec": "~/.local/scripts/checkupdate",
        "exec-if": "exit 0",
        "on-click": "kitty -e sudo pacman -Syu"
    }
}
