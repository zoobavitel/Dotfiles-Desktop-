/* Win95 Start Menu Theme for Rofi 2.0 (rofi-wayland) */

configuration {
    show-icons:         false;
    font:               "JetBrainsMono Nerd Font 11";
    hover-select:       true;
    me-select-entry:    "";
    me-accept-entry:    "MousePrimary";
}

* {
    bg:         #c0c0c0;
    bg-dark:    #808080;
    bg-light:   #ffffff;
    fg:         #000000;
    highlight:  #000080;
    hilite-fg:  #ffffff;
    teal:       #008080;

    background-color:   @bg;
    text-color:         @fg;
}

window {
    anchor:             southwest;
    location:           southwest;
    width:              260px;
    x-offset:           0;
    y-offset:           0;
    background-color:   @bg;
    border:             2px;
    border-color:       @bg-light;
    children:           [ horibox ];
}

horibox {
    orientation:        horizontal;
    children:           [ textbox-sidebar, mainbox ];
    background-color:   @bg;
}

textbox-sidebar {
    expand:             false;
    content:            "  ";
    background-color:   @teal;
    text-color:         @teal;
    padding:            200px 12px;
}

mainbox {
    orientation:        vertical;
    children:           [ inputbar, listview ];
    background-color:   @bg;
    padding:            2px;
}

inputbar {
    children:           [ entry ];
    background-color:   @bg;
    padding:            4px 6px;
    border:             0 0 1px 0;
    border-color:       @bg-dark;
}

entry {
    background-color:   @bg-light;
    text-color:         @fg;
    padding:            4px 6px;
    border:             1px;
    border-color:       @bg-dark;
    placeholder:        "Type to search...";
    placeholder-color:  @bg-dark;
}

listview {
    background-color:   @bg;
    columns:            1;
    lines:              9;
    spacing:            0px;
    padding:            2px 0;
    scrollbar:          false;
    fixed-height:       true;
    dynamic:            false;
}

element {
    background-color:   @bg;
    text-color:         @fg;
    padding:            5px 8px;
}

element selected.normal {
    background-color:   @highlight;
    text-color:         @hilite-fg;
}

element-text {
    background-color:   inherit;
    text-color:         inherit;
}

element-text selected.normal {
    text-color:         @hilite-fg;
}
